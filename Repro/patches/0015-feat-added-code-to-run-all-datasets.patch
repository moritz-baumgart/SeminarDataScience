+def train_one_epoch(source_loaders):
+    model.train()
+    train_loss_sum = 0.0
+    class_y_loss_sum = 0.0
+    total = 0
+
+    for source_loader in source_loaders:
+        for x, y, d in source_loader:
+            x = x.to(DEVICE)
+            y = y.to(DEVICE).long().view(-1)
+            d = d.to(DEVICE).long().view(-1)
